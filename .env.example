# Environment Configuration
NODE_ENV=development
PORT=5000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/echoverse
# Or for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/echoverse

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Logging
LOG_TO_FILE=false

# Features (toggle features on/off)
ENABLE_AI_NPC=true
ENABLE_VOICE_CHAT=false

# Rate Limiting (in development these are automatically disabled)
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_PUBLIC=30
